# Copy this file to .env and fill in your values
# Never commit .env to git

# Your deployer wallet private key (with 0x prefix)
PRIVATE_KEY=0x_your_private_key_here

# Fee recipient address (receives 1% protocol fee on resolved markets)
# Defaults to deployer if not set
FEE_RECIPIENT=0x_your_address_here

# Set to "true" to verify contract after deploy (if block explorer supports it)
VERIFY=false
